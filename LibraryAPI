--  KEY SYSTEM  [FIX + NEW animations]
-- ═════════════════════════════════════════════════════════════════════════════
--[[
    xev0r:KeySystem(opt)
    opt.Title       [string]        - tytuł okna
    opt.Subtitle    [string]        - podtytuł
    opt.Keys        [table<string>] - lista ważnych kluczy
    opt.KeyLink     [string]        - link do pobrania klucza (opcjonalnie)
    opt.SaveKey     [bool]          - zapamiętaj klucz lokalnie (domyślnie true)
    opt.MaxAttempts [number]        - ile prób przed kickiem (domyślnie 3)
    opt.Callback    [function]      - wywołana po poprawnym kluczu
]]
function xev0r:KeySystem(opt)
    opt = opt or {}
    local validKeys   = opt.Keys        or { "xev0r-free" }
    local title       = opt.Title       or "xev0r Hub"
    local subtitle    = opt.Subtitle    or "Wprowadź klucz aby kontynuować"
    local keyLink     = opt.KeyLink     or ""
    local saveKey     = opt.SaveKey     ~= false
    local maxAttempts = opt.MaxAttempts or 3
    local callback    = opt.Callback    or function() end

    local saveId      = "xev0r_key_" .. title:lower():gsub("%s", "_")
    local attempts    = 0
    local confirming  = false

    -- Sprawdzenie zapisanego klucza
    if saveKey and readfile then
        local ok, saved = pcall(readfile, saveId .. ".txt")
        if ok and saved and saved ~= "" then
            for _, k in ipairs(validKeys) do
                if k == saved then 
                    callback()
                    return 
                end
            end
        end
    end

    local sg = New("ScreenGui", {
        Name = "xev0r_KeySystem",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        Parent = PlayerGui,
    })

    local blur = New("BlurEffect", { Size = 0, Parent = Lighting })
    Tw(blur, { Size = 24 }, 0.35, Enum.EasingStyle.Quad)

    New("Frame", {
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.45,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 1,
        Parent = sg,
    })

    local CARD_W = 420
    local HAS_LINK = keyLink ~= ""
    local CARD_H = HAS_LINK and 360 or 325

    local card = New("Frame", {
        BackgroundColor3 = T.BG,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = 2,
        Parent = sg,
    })
    Corner(16, card)
    Stroke(T.Border, 1.5, card)

    Tw(card, { Size = UDim2.new(0, CARD_W, 0, CARD_H) }, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- Ikona
    local iconBg = New("Frame", {
        BackgroundColor3 = T.Surface,
        Size = UDim2.new(0, 64, 0, 64),
        Position = UDim2.new(0.5, 0, 0, 24),
        AnchorPoint = Vector2.new(0.5, 0),
        ZIndex = 3,
        Parent = card,
    })
    Corner(14, iconBg)
    Stroke(T.Border, 1.5, iconBg)
    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1,0,1,0),
        Text = "🔑",
        TextColor3 = T.AccentHi or Color3.fromRGB(255, 140, 60),
        TextSize = 28,
        Font = Enum.Font.GothamBold,
        ZIndex = 4,
        Parent = iconBg,
    })

    -- Tytuł
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 104),
        Size = UDim2.new(1, 0, 0, 26),
        Text = title,
        TextColor3 = T.TextPri,
        TextSize = 20,
        Font = Enum.Font.GothamBold,
        ZIndex = 3,
        Parent = card,
    })

    New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 130),
        Size = UDim2.new(1, 0, 0, 16),
        Text = subtitle,
        TextColor3 = T.TextSec,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ZIndex = 3,
        Parent = card,
    })

    -- Input
    local ibg = New("Frame", {
        BackgroundColor3 = T.Surface,
        Position = UDim2.new(0, 28, 0, 165),
        Size = UDim2.new(1, -56, 0, 46),
        ZIndex = 3,
        Parent = card,
    })
    Corner(12, ibg)
    local ibgStroke = Stroke(Color3.fromRGB(60, 60, 60), 1.5, ibg)

    local ibox = New("TextBox", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(1, -32, 1, 0),
        PlaceholderText = "Wklej klucz tutaj...",
        PlaceholderColor3 = T.TextMut,
        TextColor3 = T.TextPri,
        TextSize = 14,
        Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        ZIndex = 4,
        Parent = ibg,
    })

    ibox.Focused:Connect(function()
        Tw(ibgStroke, {Color = T.AccentHi}, 0.2)
    end)
    ibox.FocusLost:Connect(function()
        Tw(ibgStroke, {Color = Color3.fromRGB(60, 60, 60)}, 0.2)
    end)

    -- === POPRAWIONE PRZYCISKI ===
    local btnY = 225
    local btnH = 42
    local padding = 28
    local gap = 14

    if HAS_LINK then
        local getBtn = New("TextButton", {
            BackgroundColor3 = T.Surface,
            Position = UDim2.new(0, padding, 0, btnY),
            Size = UDim2.new(0.5, -padding - gap/2, 0, btnH),
            Text = "Pobierz klucz",
            TextColor3 = T.TextSec,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            ZIndex = 4,
            Parent = card,
        })
        Corner(10, getBtn)
        Stroke(T.Border, 1.5, getBtn)

        getBtn.MouseButton1Click:Connect(function()
            if setclipboard then setclipboard(keyLink) end
            xev0r:Notify({Title = "KeySystem", Message = "Link skopiowany!", Type = "info"})
        end)
    end

    local confirmBtn = New("TextButton", {
        BackgroundColor3 = T.Accent,
        Position = HAS_LINK and UDim2.new(0.5, gap/2, 0, btnY) or UDim2.new(0, padding, 0, btnY),
        Size = HAS_LINK and UDim2.new(0.5, -padding - gap/2, 0, btnH) or UDim2.new(1, -padding*2, 0, btnH),
        Text = "Potwierdź",
        TextColor3 = Color3.fromRGB(0, 0, 0),
        TextSize = 13.5,
        Font = Enum.Font.GothamBold,
        ZIndex = 4,
        Parent = card,
    })
    Corner(10, confirmBtn)

    -- Reszta funkcji (destroyUI + tryConfirm) bez zmian
    local function destroyUI()
        Tw(blur, { Size = 0 }, 0.25)
        Tw(card, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 }, 0.32, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.35)
        sg:Destroy()
        blur:Destroy()
    end

    local function tryConfirm()
        if confirming then return end
        confirming = true

        local input = ibox.Text:match("^%s*(.-)%s*$")
        local valid = false
        for _, k in ipairs(validKeys) do
            if input == k then valid = true break end
        end

        if valid then
            confirmBtn.Text = "✓ Poprawny"
            confirmBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 100)
            if saveKey and writefile then pcall(writefile, saveId .. ".txt", input) end
            task.wait(0.8)
            destroyUI()
            callback()
        else
            attempts += 1
            confirmBtn.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
            task.wait(0.45)
            confirmBtn.BackgroundColor3 = T.Accent
            confirming = false

            if attempts >= maxAttempts then
                xev0r:Notify({Title = "KeySystem", Message = "Zbyt wiele prób!", Type = "error"})
                task.wait(1)
                destroyUI()
                Players.LocalPlayer:Kick("[xev0r] Za dużo niepoprawnych prób.")
            end
        end
    end

    confirmBtn.MouseButton1Click:Connect(tryConfirm)
    ibox.FocusLost:Connect(function(enter) if enter then tryConfirm() end end)

    task.delay(0.5, function()
        if ibox and ibox.Parent then ibox:CaptureFocus() end
    end)
end

