                    s = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
                    v = 1 - math.clamp((i.Position.Y - ap.Y) / as.Y, 0, 1)
                    updateColor()
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDrag = false
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if svDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
                    local ap = svFrame.AbsolutePosition; local as = svFrame.AbsoluteSize
                    s = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
                    v = 1 - math.clamp((i.Position.Y - ap.Y) / as.Y, 0, 1)
                    updateColor()
