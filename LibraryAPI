                BorderSizePixel  = 0,
                Size             = UDim2.new(1, -24, 0, 5),
                Position         = UDim2.new(0, 12, 0, desc and 40 or 32),
                Parent           = row,
            })
            Corner(3, trackBg)

            local pct  = (val - min) / (max - min)
            local fill = New("Frame", {
                BackgroundColor3 = T.Accent,
                BorderSizePixel  = 0,
                Size             = UDim2.new(pct, 0, 1, 0),
                Parent           = trackBg,
            })
            Corner(3, fill)
            local knob = New("Frame", {
                BackgroundColor3 = T.White,
                BorderSizePixel  = 0,
                Size             = UDim2.new(0, 13, 0, 13),
                Position         = UDim2.new(pct, -6, 0.5, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                Parent           = trackBg,
            })
            Corner(7, knob)

            local function applyVal(v)
                v = math.clamp(math.floor(v + 0.5), min, max)
                val = v; valLbl.Text = tostring(v)
                local p = (v - min) / (max - min)
                fill.Size     = UDim2.new(p, 0, 1, 0)
                knob.Position = UDim2.new(p, -6, 0.5, 0)
                if callback then callback(v) end
            end

            -- [FIX] Drag działa przez cały ekran
            local sliding = false
            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    local rel = math.clamp((i.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                    applyVal(min + rel * (max - min))
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
                    local rel = math.clamp((i.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                    applyVal(min + rel * (max - min))
                end
            end)

            local el = {}
            function el:SetValue(v) applyVal(v) end
            function el:GetValue()  return val end
            regEl(id, function() return val end, function(v) applyVal(v) end)
            return el
        end

