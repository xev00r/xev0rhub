--  WATERMARK
-- ═════════════════════════════════════════════════════════════════════════════
local _wmFrame

--[[
    xev0r:CreateWatermark(opt)
    opt.Text     [string]  - tekst bazowy
    opt.Position [UDim2]   - pozycja na ekranie
    opt.ShowFPS  [bool]    - czy pokazywać FPS (domyślnie true)
    opt.ShowTime [bool]    - czy pokazywać czas gry (domyślnie false)
    Zwraca: { SetText, Destroy, Toggle, SetVisible }
]]
function xev0r:CreateWatermark(opt)
    opt = opt or {}
    local baseText = opt.Text     or "xev0r"
    local showFPS  = opt.ShowFPS  ~= false
    local showTime = opt.ShowTime or false
    local pos      = opt.Position or UDim2.new(0, 8, 0, 8)

    if _wmFrame then _wmFrame:Destroy() end

    local sg = New("ScreenGui", {
        Name           = "xev0r_WM",
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        Parent         = PlayerGui,
    })

    _wmFrame = New("Frame", {
        BackgroundColor3 = T.Surface,
        BorderSizePixel  = 0,
        Position         = pos,
        Size             = UDim2.new(0, 0, 0, 26),
        AutomaticSize    = Enum.AutomaticSize.X,
        Parent           = sg,
    })
    Corner(7, _wmFrame)
    Stroke(T.Border, 1, _wmFrame)
    Pad(0, 0, 10, 10, _wmFrame)

    local lbl = New("TextLabel", {
        BackgroundTransparency = 1,
        Size          = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Text          = baseText,
        TextColor3    = T.TextPri,
        TextSize      = 11,
        Font          = Enum.Font.GothamBold,
        Parent        = _wmFrame,
    })

    -- [CLEAN] Usunięto zduplikowany RenderStepped — tylko Heartbeat
    local startTick = tick()
    local fps       = 60
    local lastFrame = tick()

    RunService.Heartbeat:Connect(function()
        if not lbl.Parent then return end
        local now = tick()
        fps       = math.floor(0.9 * fps + 0.1 * (1 / (now - lastFrame + 0.0001)))
        lastFrame = now

        local parts = { baseText }
        if showFPS  then parts[#parts + 1] = "| " .. fps .. " fps" end
        if showTime then
            local s = math.floor(tick() - startTick)
            parts[#parts + 1] = "| " .. string.format("%02d:%02d", math.floor(s / 60), s % 60)
        end
        lbl.Text = table.concat(parts, " ")
    end)

    local visible = true
    local wm = {}
    function wm:SetText(t)    baseText = t end
    function wm:Destroy()     sg:Destroy() end
    function wm:Toggle()      visible = not visible; _wmFrame.Visible = visible end
    function wm:SetVisible(v) visible = v;           _wmFrame.Visible = v end
    return wm
end

