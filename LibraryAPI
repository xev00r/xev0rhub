        -- ── SEPARATOR ────────────────────────────────────────────────────
        --[[
            tab:AddSeparator()
            Pozioma linia oddzielająca elementy.
        ]]
        function tab:AddSeparator()
            New("Frame",{BackgroundColor3=T.Border,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,1),Parent=scroll})
        end

        -- ── LABEL ────────────────────────────────────────────────────────
        --[[
            tab:AddLabel(text, id)
            Pasywny tekst informacyjny.
            Metody zwróconego obiektu:
