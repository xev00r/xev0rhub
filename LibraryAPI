            function el:SetText(t) lf.Text=t end
            regEl(id, function() return lf.Text end, function(v) lf.Text=v end)
            return el
        end

        -- ── IMAGE ─────────────────────────────────────────────────────────
        --[[
            tab:AddImage(options)
            options:
                Image  [string]  - rbxassetid://...
                Size   [Vector2] - rozmiar (domyślnie 200x100)
                Label  [string]  - opcjonalny podpis
