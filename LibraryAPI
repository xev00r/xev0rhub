--  CREATE WINDOW
-- ═════════════════════════════════════════════════════════════════════════════
--[[
    xev0r:CreateWindow(opt)
    opt.Title    [string]  - tytuł okna
    opt.Subtitle [string]  - podtytuł
    opt.Size     [Vector2] - rozmiar okna (domyślnie 620×430)
    opt.ConfigId [string]  - klucz do zapisu konfiguracji
    Zwraca: Window z metodami AddTab, SetTab, Destroy, Toggle, SaveConfig, LoadConfig
]]
function xev0r:CreateWindow(opt)
    opt = opt or {}
    local winTitle    = opt.Title    or "xev0r"
