    function Win:Toggle()
        Win._visible = not Win._visible
        if Win._visible then
            main.Visible = true
            Tw(main, { Size = UDim2.new(0, winSize.X, 0, winSize.Y) }, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        else
            Tw(main, { Size = UDim2.new(0, 0, 0, 0) }, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            task.delay(0.22, function() main.Visible = false end)
        end
