                    Tw(wrapper, { Size = UDim2.new(1, 0, 0, 34 + panelH + 3) }, 0.2)
                else
                    Tw(panel, { Size = UDim2.new(1, 0, 0, 0) }, 0.16)
                    Tw(wrapper, { Size = UDim2.new(1, 0, 0, 34) }, 0.16)
                end
            end)

            local el = {}
            function el:SetColor(c)
                color = c; h, s, v = RGB2HSV(c); updateColor()
            end
            function el:GetColor() return color end
            regEl(id,
                function() return { R = color.R, G = color.G, B = color.B } end,
                function(d)
                    if type(d) == "table" then el:SetColor(Color3.new(d.R, d.G, d.B)) end
                end)
            return el
        end

        -- ── PROGRESS BAR ───────────────────────────────────────────────
        function tab:AddProgressBar(label, default)
            local val = math.clamp(default or 0, 0, 100)

            local row = New("Frame", {
                BackgroundColor3 = T.Surface,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, 0, 0, 48),
                Parent           = scroll,
            })
            Corner(8, row); Stroke(T.Border, 1, row)

            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 6),
                Size           = UDim2.new(0.7, 0, 0, 15),
                Text           = label,
                TextColor3     = T.TextPri,
                TextSize       = 11,
                Font           = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent         = row,
            })
            local pctLbl = New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(1, -46, 0, 6),
                Size           = UDim2.new(0, 40, 0, 15),
                Text           = val .. "%",
                TextColor3     = T.Accent,
                TextSize       = 11,
                Font           = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent         = row,
            })

            local trackBg = New("Frame", {
                BackgroundColor3 = T.SurfaceAct,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, -24, 0, 8),
                Position         = UDim2.new(0, 12, 0, 30),
                Parent           = row,
            })
            Corner(4, trackBg)
            local fill = New("Frame", {
                BackgroundColor3 = T.Accent,
                BorderSizePixel  = 0,
                Size             = UDim2.new(val / 100, 0, 1, 0),
                Parent           = trackBg,
            })
            Corner(4, fill)

            local el = {}
            function el:SetValue(n)
                n = math.clamp(n, 0, 100); val = n
                pctLbl.Text = n .. "%"
                Tw(fill, { Size = UDim2.new(n / 100, 0, 1, 0) }, 0.25)
            end
            function el:GetValue() return val end
            return el
        end

        return tab
    end -- AddTab

    return Win
end -- CreateWindow

return xev0r
