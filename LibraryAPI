    function Win:SetTab(name)
        for _, t in ipairs(Win._tabs) do
            if t._name == name then t._activate(); return end
        end
    end

    function Win:SaveConfig()
        local data = {}
        for id, el in pairs(Win._elements) do
            data[id] = el._getValue and el._getValue() or nil
        end
        local json = HttpService:JSONEncode(data)
        if writefile then pcall(writefile, Win._configId .. ".json", json) end
        return json
    end

    function Win:LoadConfig(jsonStr)
        local ok, data
        if jsonStr then
            ok, data = pcall(HttpService.JSONDecode, HttpService, jsonStr)
        elseif readfile then
            local s; ok, s = pcall(readfile, Win._configId .. ".json")
            if ok and s then ok, data = pcall(HttpService.JSONDecode, HttpService, s) end
        end
        if not (ok and data) then return end
        for id, val in pairs(data) do
            if Win._elements[id] and Win._elements[id]._setValue then
                Win._elements[id]._setValue(val)
            end
        end
    end

