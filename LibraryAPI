    -- ── Window-level methods ──────────────────────────────────────────────────
    function Win:Destroy() sg:Destroy() end

    function Win:Toggle()
        Win._visible = not Win._visible
        main.Visible = Win._visible
    end

    function Win:SetTab(name)
        for _,t in ipairs(Win._tabs) do
            if t._name==name then t._activate(); return end
        end
    end

    function Win:SaveConfig()
        local data={}
        for id,el in pairs(Win._elements) do
            data[id]=el._getValue and el._getValue() or nil
        end
        local json=HttpService:JSONEncode(data)
        if writefile then pcall(writefile,Win._configId..".json",json) end
        return json
    end

    function Win:LoadConfig(jsonStr)
        local ok,data
        if jsonStr then
            ok,data=pcall(HttpService.JSONDecode,HttpService,jsonStr)
        elseif readfile then
            local s; ok,s=pcall(readfile,Win._configId..".json")
            if ok and s then ok,data=pcall(HttpService.JSONDecode,HttpService,s) end
        end
        if not (ok and data) then return end
        for id,val in pairs(data) do
            if Win._elements[id] and Win._elements[id]._setValue then
                Win._elements[id]._setValue(val)
            end
        end
    end

    -- ══════════════════════════════════════════════════════════════════════
    --  ADD TAB
    -- ══════════════════════════════════════════════════════════════════════
    --[[
        win:AddTab(name, icon) -> Tab
        Zwraca obiekt Tab z metodami AddButton, AddToggle, AddSlider,
        AddDropdown, AddInput, AddTextarea, AddColorPicker, AddKeybind,
        AddSection, AddSeparator, AddLabel, AddImage, AddProgressBar
    ]]
    function Win:AddTab(name, icon)
        icon = icon or "▸"
        local tab = {}
        tab._name = name

        local scroll=New("ScrollingFrame",{BackgroundTransparency=1,BorderSizePixel=0,
            Position=UDim2.new(0,0,0,40),Size=UDim2.new(1,0,1,-40),
            ScrollBarThickness=3,ScrollBarImageColor3=T.BorderLight,
            CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false,Parent=content})
        Pad(10,10,12,12,scroll)
        New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,5),Parent=scroll})

        local btn=New("TextButton",{BackgroundColor3=T.Surface,BackgroundTransparency=1,
            BorderSizePixel=0,Size=UDim2.new(1,0,0,32),Text="",Parent=tabList})
        Corner(7,btn)

        local indic=New("Frame",{BackgroundColor3=T.Accent,BorderSizePixel=0,
            Size=UDim2.new(0,2,0.5,0),Position=UDim2.new(0,0,0.5,0),
            AnchorPoint=Vector2.new(0,0.5),Visible=false,Parent=btn}); Corner(2,indic)

        New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,10,0,0),
            Size=UDim2.new(0,20,1,0),Text=icon,TextColor3=T.TextSec,TextSize=13,
            Font=Enum.Font.Gotham,Parent=btn})
        local lbl=New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,30,0,0),
            Size=UDim2.new(1,-34,1,0),Text=name,TextColor3=T.TextSec,TextSize=11,
            Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=btn})

        local function activate()
            for _,t in ipairs(Win._tabs) do
                t._scroll.Visible=false
                Tw(t._btn,{BackgroundTransparency=1},0.1)
                t._indic.Visible=false
                t._lbl.TextColor3=T.TextSec; t._lbl.Font=Enum.Font.Gotham
            end
            scroll.Visible=true
            btn.BackgroundColor3=T.SurfaceHov
            Tw(btn,{BackgroundTransparency=0},0.1)
            indic.Visible=true
            lbl.TextColor3=T.TextPri; lbl.Font=Enum.Font.GothamBold
            topTitle.Text=name
        end

        tab._scroll=scroll; tab._btn=btn; tab._indic=indic
        tab._lbl=lbl; tab._activate=activate
        table.insert(Win._tabs,tab)

        btn.MouseButton1Click:Connect(activate)
        btn.MouseEnter:Connect(function()
            if scroll.Visible then return end
            btn.BackgroundColor3=T.SurfaceHov; Tw(btn,{BackgroundTransparency=0.3},0.1)
        end)
        btn.MouseLeave:Connect(function()
            if scroll.Visible then return end; Tw(btn,{BackgroundTransparency=1},0.1)
        end)

        if #Win._tabs==1 then activate() end

        -- ── helper: register element for config ──────────────────────────
        local function regEl(id, getV, setV)
            if not id then return end
            Win._elements[id]={_getValue=getV,_setValue=setV}
        end

