        function tab:AddKeybind(label, desc, default, callback, id)
            local currentKey = default or Enum.KeyCode.Unknown
            local listening  = false
            local h          = desc and 46 or 36
            local row        = MakeRow(h)
            New("UIGradient", { Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, Color3.fromRGB(22,22,25)), ColorSequenceKeypoint.new(1, Color3.fromRGB(17,17,19)) }), Rotation = 90, Parent = row })
 
