            Corner(7, keyBg); Stroke(T.Border, 1, keyBg)
 
            keyBg.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true; keyBg.Text = "..."; keyBg.TextColor3 = T.Warning
                local pulsing = true
                task.spawn(function()
                    while pulsing do Tw(keyBg, { BackgroundColor3 = T.SurfaceHov }, 0.3); task.wait(0.3); if not pulsing then break end; Tw(keyBg, { BackgroundColor3 = T.SurfaceAct }, 0.3); task.wait(0.3) end
                end)
                local conn; conn = UserInputService.InputBegan:Connect(function(i, gpe)
                    if gpe then return end
                    if i.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = i.KeyCode; keyBg.Text = i.KeyCode.Name; keyBg.TextColor3 = T.Accent; keyBg.BackgroundColor3 = T.SurfaceAct; pulsing = false; listening = false; conn:Disconnect()
                    end
                end)
            end)
            UserInputService.InputBegan:Connect(function(i, gpe)
                if gpe or listening then return end
                if i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode == currentKey then if callback then callback(currentKey) end end
            end)
 
            local el = {}
            function el:SetKey(k) currentKey = k; keyBg.Text = (k == Enum.KeyCode.Unknown) and "None" or k.Name end
            function el:GetKey() return currentKey end
            regEl(id, function() return currentKey.Name end, function(v) local ok,kc=pcall(function() return Enum.KeyCode[v] end); if ok and kc then el:SetKey(kc) end end)
