--  KEY SYSTEM
-- ══════════════════════════════════════════════════════════════════════════════
--[[
    xev0r:KeySystem(options)
    options:
        Title    [string]         - tytuł okna
        Subtitle [string]         - podtytuł
        Keys     [table<string>]  - lista ważnych kluczy
        KeyLink  [string]         - link do pobrania klucza (kopiowany do schowka)
        SaveKey  [bool]           - zapamiętaj klucz lokalnie (domyślnie true)
        Callback [function]       - wywołana po poprawnym kluczu
]]
function xev0r:KeySystem(opt)
    opt = opt or {}
    local validKeys = opt.Keys     or {"xev0r-free"}
    local title     = opt.Title    or "xev0r"
    local subtitle  = opt.Subtitle or "Wpisz klucz aby kontynuować"
    local keyLink   = opt.KeyLink  or ""
    local saveKey   = opt.SaveKey  ~= false
    local callback  = opt.Callback or function() end
    local saveId    = "xev0r_key_"..title:lower():gsub("%s","_")

    -- check saved key
    if saveKey then
        local ok, saved = pcall(function() return readfile and readfile(saveId..".txt") or nil end)
        if ok and saved then
            for _,k in ipairs(validKeys) do
                if k == saved then callback(); return end
            end
        end
    end

    local sg = New("ScreenGui",{Name="xev0r_Key",ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,Parent=PlayerGui})
    New("Frame",{BackgroundColor3=T.Black,BackgroundTransparency=0.48,
        Size=UDim2.new(1,0,1,0),BorderSizePixel=0,Parent=sg})

    local card=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
        Size=UDim2.new(0,375,0,248),Position=UDim2.new(0.5,0,0.5,0),
        AnchorPoint=Vector2.new(0.5,0.5),Parent=sg})
    Corner(12,card); Stroke(T.Border,1,card)

    local strip=New("Frame",{BackgroundColor3=T.BorderLight,BorderSizePixel=0,
        Size=UDim2.new(1,0,0,2),Parent=card}); Corner(12,strip)

    local iconBg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
        Size=UDim2.new(0,44,0,44),Position=UDim2.new(0.5,0,0,20),
        AnchorPoint=Vector2.new(0.5,0),Parent=card}); Corner(10,iconBg)
    New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
        Text="🔑",TextSize=20,Font=Enum.Font.Gotham,Parent=iconBg})

    New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,18,0,74),
        Size=UDim2.new(1,-36,0,20),Text=title,TextColor3=T.TextPri,TextSize=15,
        Font=Enum.Font.GothamBold,Parent=card})
    New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,18,0,94),
        Size=UDim2.new(1,-36,0,16),Text=subtitle,TextColor3=T.TextSec,TextSize=10,
        Font=Enum.Font.Gotham,Parent=card})

    local ibg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
        Size=UDim2.new(1,-36,0,36),Position=UDim2.new(0,18,0,120),Parent=card})
    Corner(7,ibg); Stroke(T.Border,1,ibg)
    local ibox=New("TextBox",{BackgroundTransparency=1,
        Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-20,1,0),
        PlaceholderText="Wpisz klucz...",PlaceholderColor3=T.TextMut,
        TextColor3=T.TextPri,TextSize=11,Font=Enum.Font.GothamMono,
        TextXAlignment=Enum.TextXAlignment.Left,ClearTextOnFocus=false,Parent=ibg})
    ibox.Focused:Connect(function()
        Tw(ibg:FindFirstChildOfClass("UIStroke"),{Color=T.Accent},0.12)
    end)
    ibox.FocusLost:Connect(function()
        Tw(ibg:FindFirstChildOfClass("UIStroke"),{Color=T.Border},0.12)
    end)

    local statusLbl=New("TextLabel",{BackgroundTransparency=1,
        Position=UDim2.new(0,18,0,163),Size=UDim2.new(1,-36,0,14),
        Text="",TextColor3=T.Danger,TextSize=10,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=card})

    local confirmBtn=New("TextButton",{BackgroundColor3=T.SurfaceHov,BorderSizePixel=0,
        Size=UDim2.new(0,145,0,32),Position=UDim2.new(1,-163,0,202),
        Text="Potwierdź klucz",TextColor3=T.TextPri,TextSize=11,
        Font=Enum.Font.GothamBold,Parent=card})
    Corner(7,confirmBtn); Stroke(T.Border,1,confirmBtn)

    if keyLink~="" then
        local gb=New("TextButton",{BackgroundColor3=T.Surface,BorderSizePixel=0,
            Size=UDim2.new(0,110,0,32),Position=UDim2.new(0,18,0,202),
            Text="Pobierz klucz",TextColor3=T.TextSec,TextSize=11,
            Font=Enum.Font.Gotham,Parent=card})
        Corner(7,gb); Stroke(T.Border,1,gb)
        gb.MouseButton1Click:Connect(function()
            if setclipboard then setclipboard(keyLink) end
            xev0r:Notify({Title="xev0r",Message="Link skopiowany do schowka!",Type="info"})
        end)
    end

    confirmBtn.MouseEnter:Connect(function() Tw(confirmBtn,{BackgroundColor3=T.SurfaceAct},0.1) end)
    confirmBtn.MouseLeave:Connect(function() Tw(confirmBtn,{BackgroundColor3=T.SurfaceHov},0.1) end)
    confirmBtn.MouseButton1Click:Connect(function()
        local ok=false
        for _,k in ipairs(validKeys) do if k==ibox.Text then ok=true; break end end
        if ok then
            statusLbl.TextColor3=T.Success; statusLbl.Text="✓ Poprawny klucz. Ładowanie..."
            if saveKey and writefile then pcall(writefile,saveId..".txt",ibox.Text) end
            task.wait(0.7); sg:Destroy(); callback()
        else
            statusLbl.TextColor3=T.Danger; statusLbl.Text="✕ Nieprawidłowy klucz."
            Tw(ibg,{BackgroundColor3=Color3.fromRGB(50,22,22)},0.08)
            task.wait(0.3); Tw(ibg,{BackgroundColor3=T.SurfaceAct},0.18)
        end
    end)
end

