--  WATERMARK
-- ══════════════════════════════════════════════════════════════════════════════
local _wmFrame

--[[
    xev0r:CreateWatermark(options)
    options:
        Text     [string]  - tekst bazowy (np. "xev0r | v1.0")
        Position [UDim2]   - pozycja na ekranie
        ShowFPS  [bool]    - czy pokazywać FPS (domyślnie true)
        ShowTime [bool]    - czy pokazywać czas gry (domyślnie false)
    zwraca obiekt watermark z metodami:
        :SetText(text)     - zmień tekst
        :Destroy()         - usuń watermark
        :Toggle()          - pokaż/ukryj
]]
function xev0r:CreateWatermark(opt)
    opt = opt or {}
    local baseText = opt.Text     or "xev0r"
    local showFPS  = opt.ShowFPS  ~= false
    local showTime = opt.ShowTime or false
    local pos      = opt.Position or UDim2.new(0,8,0,8)

    if _wmFrame then _wmFrame:Destroy() end

    local sg = New("ScreenGui",{Name="xev0r_WM",ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,Parent=PlayerGui})

    _wmFrame = New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
        Position=pos,Size=UDim2.new(0,0,0,26),AutomaticSize=Enum.AutomaticSize.X,
        Parent=sg})
    Corner(7,_wmFrame); Stroke(T.Border,1,_wmFrame); Pad(0,0,10,10,_wmFrame)

    local lbl = New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(0,0,1,0),
        AutomaticSize=Enum.AutomaticSize.X,Text=baseText,TextColor3=T.TextPri,
        TextSize=11,Font=Enum.Font.GothamBold,Parent=_wmFrame})

    local startTick = tick()
    local visible = true

    local conn = RunService.RenderStepped:Connect(function()
        if not lbl.Parent then return end
        local parts = {baseText}
        if showFPS then
            local fps = math.floor(1/RunService.RenderStepped:Wait()*0 + (1/0.016))
            -- lightweight fps via delta
            parts[#parts+1] = "| FPS: "..math.floor(1/(RunService.RenderStepped:Wait()+0.001)+0.5)
        end
        if showTime then
            local s = math.floor(tick()-startTick)
            parts[#parts+1] = "| "..string.format("%02d:%02d",math.floor(s/60),s%60)
        end
        lbl.Text = table.concat(parts," ")
    end)

    -- simpler fps via heartbeat
    local lastFrame = tick()
    local fps = 60
    RunService.Heartbeat:Connect(function()
        local now = tick()
        fps = math.floor(0.9*fps + 0.1*(1/(now-lastFrame+0.0001)))
        lastFrame = now
        if not lbl.Parent then return end
        local parts = {baseText}
        if showFPS  then parts[#parts+1] = "| "..fps.." fps" end
        if showTime then
            local s=math.floor(tick()-startTick)
            parts[#parts+1]="| "..string.format("%02d:%02d",math.floor(s/60),s%60)
        end
        lbl.Text = table.concat(parts," ")
    end)

    local wm = {}
    function wm:SetText(t) baseText=t end
    function wm:Destroy() sg:Destroy() end
    function wm:Toggle()
        visible = not visible
        _wmFrame.Visible = visible
    end
    function wm:SetVisible(v)
        visible = v
        _wmFrame.Visible = v
    end
    return wm
end

