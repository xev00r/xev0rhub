local _nSG, _nHolder
local function EnsureNotifs()
    if _nHolder and _nHolder.Parent then return end
    _nSG = New("ScreenGui",{Name="xev0r_Notifs",ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,Parent=PlayerGui})
    _nHolder = New("Frame",{BackgroundTransparency=1,AnchorPoint=Vector2.new(1,1),
        Position=UDim2.new(1,-14,1,-14),Size=UDim2.new(0,310,1,0),Parent=_nSG})
    New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalAlignment=Enum.VerticalAlignment.Bottom,Padding=UDim.new(0,6),Parent=_nHolder})
end

local NCol  = {success=T.Success,warning=T.Warning,error=T.Danger,info=T.Info}
local NIco  = {success="✓",warning="!",error="✕",info="i"}

--[[
    xev0r:Notify(options)
    options:
        Title    [string]  - tytuł powiadomienia
        Message  [string]  - treść
        Type     [string]  - "success" | "warning" | "error" | "info"
        Duration [number]  - czas w sekundach (domyślnie 4)
]]
function xev0r:Notify(opt)
    EnsureNotifs()
    opt = opt or {}
    local title    = opt.Title    or "Notification"
    local msg      = opt.Message  or ""
    local ntype    = opt.Type     or "info"
    local duration = opt.Duration or 4
    local col      = NCol[ntype]  or T.Accent

    local card = New("Frame",{BackgroundColor3=T.Surface,BackgroundTransparency=1,
        BorderSizePixel=0,Size=UDim2.new(1,0,0,64),ClipsDescendants=true,Parent=_nHolder})
    Corner(10,card); Stroke(T.Border,1,card)

    local bar=New("Frame",{BackgroundColor3=col,BorderSizePixel=0,
        Size=UDim2.new(0,3,1,0),Parent=card}); Corner(3,bar)

    local ic=New("Frame",{BackgroundColor3=col,BorderSizePixel=0,
        Size=UDim2.new(0,26,0,26),Position=UDim2.new(0,14,0.5,0),
        AnchorPoint=Vector2.new(0,0.5),Parent=card}); Corner(13,ic)
    New("TextLabel",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
        Text=NIco[ntype] or "i",TextColor3=T.BG,TextSize=12,
        Font=Enum.Font.GothamBold,Parent=ic})

    New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,50,0,8),
        Size=UDim2.new(1,-62,0,18),Text=title,TextColor3=T.TextPri,TextSize=12,
        Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=card})
    New("TextLabel",{BackgroundTransparency=1,Position=UDim2.new(0,50,0,27),
        Size=UDim2.new(1,-62,0,26),Text=msg,TextColor3=T.TextSec,TextSize=10,
        Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,
        TextWrapped=true,Parent=card})

    local pbg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
        Size=UDim2.new(1,-18,0,2),Position=UDim2.new(0,9,1,-4),Parent=card}); Corner(2,pbg)
    local pbar=New("Frame",{BackgroundColor3=col,BorderSizePixel=0,
        Size=UDim2.new(1,0,1,0),Parent=pbg}); Corner(2,pbar)

    Tw(card,{BackgroundTransparency=0},0.22)
    Tw(pbar,{Size=UDim2.new(0,0,1,0)},duration,Enum.EasingStyle.Linear)
    task.delay(duration,function()
        Tw(card,{BackgroundTransparency=1},0.22)
        task.wait(0.25); card:Destroy()
    end)
end

