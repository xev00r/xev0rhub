        function tab:AddKeybind(label, desc, default, callback, id)
            local currentKey = default or Enum.KeyCode.Unknown
            local listening  = false
            local h          = desc and 44 or 34

            local row = New("Frame", {
                BackgroundColor3 = T.Surface,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, 0, 0, h),
                Parent           = scroll,
            })
            Corner(8, row); Stroke(T.Border, 1, row)

            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, desc and 6 or 0),
                Size           = UDim2.new(1, -90, 0, desc and 18 or h),
                Text           = label,
                TextColor3     = T.TextPri,
                TextSize       = 11,
                Font           = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent         = row,
            })
            if desc then
                New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position       = UDim2.new(0, 12, 0, 24),
                    Size           = UDim2.new(1, -90, 0, 14),
                    Text           = desc,
                    TextColor3     = T.TextMut,
                    TextSize       = 9,
                    Font           = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent         = row,
                })
            end

            local keyBg = New("TextButton", {
                BackgroundColor3 = T.SurfaceAct,
                BorderSizePixel  = 0,
                Size             = UDim2.new(0, 74, 0, h - 10),
                Position         = UDim2.new(1, -82, 0.5, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                Text             = (currentKey == Enum.KeyCode.Unknown) and "None" or currentKey.Name,
                TextColor3       = T.Accent,
                TextSize         = 10,
                Font             = Enum.Font.GothamBold,
                Parent           = row,
            })
            Corner(6, keyBg); Stroke(T.Border, 1, keyBg)

            keyBg.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyBg.Text      = "..."
                keyBg.TextColor3 = T.Warning
                -- [NEW] Pulsowanie podczas oczekiwania
                local pulsing = true
                task.spawn(function()
                    while pulsing do
                        Tw(keyBg, { BackgroundColor3 = T.SurfaceHov }, 0.3)
                        task.wait(0.3)
                        if not pulsing then break end
                        Tw(keyBg, { BackgroundColor3 = T.SurfaceAct }, 0.3)
                        task.wait(0.3)
                    end
                end)
                local conn; conn = UserInputService.InputBegan:Connect(function(i, gpe)
                    if gpe then return end
                    if i.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = i.KeyCode
                        keyBg.Text       = i.KeyCode.Name
                        keyBg.TextColor3 = T.Accent
                        keyBg.BackgroundColor3 = T.SurfaceAct
                        pulsing  = false
                        listening = false
                        conn:Disconnect()
                    end
                end)
            end)

            UserInputService.InputBegan:Connect(function(i, gpe)
                if gpe or listening then return end
                if i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode == currentKey then
                    if callback then callback(currentKey) end
                end
            end)

            local el = {}
            function el:SetKey(k)
                currentKey = k
                keyBg.Text = (k == Enum.KeyCode.Unknown) and "None" or k.Name
            end
            function el:GetKey() return currentKey end
            regEl(id,
                function() return currentKey.Name end,
                function(v)
                    local ok, kc = pcall(function() return Enum.KeyCode[v] end)
                    if ok and kc then el:SetKey(kc) end
                end)
            return el
        end

