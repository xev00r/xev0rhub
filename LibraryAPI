        function tab:AddImage(opt2)
            opt2 = opt2 or {}
            local imgSize = opt2.Size or Vector2.new(200,100)
            local h = imgSize.Y + (opt2.Label and 22 or 0) + 16

            local frame=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,h),Parent=scroll})
