            Parent     = btn,
        })
        local lbl = New("TextLabel", {
            BackgroundTransparency = 1,
            Position       = UDim2.new(0, 30, 0, 0),
            Size           = UDim2.new(1, -34, 1, 0),
            Text           = name,
            TextColor3     = T.TextSec,
            TextSize       = 11,
            Font           = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent         = btn,
        })

        -- [NEW] Tab switch z fade
        local function activate()
            for _, t in ipairs(Win._tabs) do
                if t._scroll.Visible then
                    Tw(t._scroll, { GroupTransparency = 1 }, 0.1)
                    task.delay(0.12, function()
                        t._scroll.Visible = false
                        t._scroll.GroupTransparency = 0
                    end)
                end
                Tw(t._btn, { BackgroundTransparency = 1 }, 0.1)
                t._indic.Visible = false
                t._lbl.TextColor3 = T.TextSec
                t._lbl.Font = Enum.Font.Gotham
            end
            task.delay(0.1, function()
                scroll.Visible = true
                scroll.GroupTransparency = 1
                Tw(scroll, { GroupTransparency = 0 }, 0.15)
            end)
            btn.BackgroundColor3 = T.SurfaceHov
            Tw(btn, { BackgroundTransparency = 0 }, 0.1)
            indic.Visible = true
            lbl.TextColor3 = T.TextPri
            lbl.Font = Enum.Font.GothamBold
            topTitle.Text = name
        end

        tab._scroll   = scroll
        tab._btn      = btn
        tab._indic    = indic
        tab._lbl      = lbl
        tab._activate = activate
        table.insert(Win._tabs, tab)

        btn.MouseButton1Click:Connect(activate)
        btn.MouseEnter:Connect(function()
            if scroll.Visible then return end
            btn.BackgroundColor3 = T.SurfaceHov
            Tw(btn, { BackgroundTransparency = 0.3 }, 0.1)
        end)
        btn.MouseLeave:Connect(function()
            if scroll.Visible then return end
            Tw(btn, { BackgroundTransparency = 1 }, 0.1)
        end)

        if #Win._tabs == 1 then activate() end

