        Position=UDim2.new(0,14,0,0),Size=UDim2.new(1,-50,1,0),
        Text="—",TextColor3=T.TextPri,TextSize=12,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=topBar})

    local minBtn=New("TextButton",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
        Size=UDim2.new(0,26,0,26),Position=UDim2.new(1,-34,0.5,0),
