            local function applyVal(v)
                v = math.clamp(math.floor(v + 0.5), min, max); val = v; valLbl.Text = tostring(v)
                local p = (v - min) / (max - min)
                fill.Size = UDim2.new(p, 0, 1, 0); knob.Position = UDim2.new(p, -6, 0.5, 0)
                if callback then callback(v) end
            end
 
            local sliding = false
            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    applyVal(min + math.clamp((i.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1) * (max - min))
                end
            end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
            UserInputService.InputChanged:Connect(function(i)
                if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
                    applyVal(min + math.clamp((i.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1) * (max - min))
                end
            end)
 
            local el = {}
            function el:SetValue(v) applyVal(v) end
            function el:GetValue()  return val end
            regEl(id, function() return val end, function(v) applyVal(v) end)
            return el
        end
 
        -- DROPDOWN z click-outside
        function tab:AddDropdown(label, items, default, callback, id)
            local selected = default or (items[1] or "Wybierz...")
            local open     = false
            local outsideConn = nil

            local wrapper = New("Frame", { BackgroundTransparency = 1, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 36), ClipsDescendants = false, Parent = scroll })
