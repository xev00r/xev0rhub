                    TextSize       = 9,
                    Font           = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent         = row,
                })
            end

            local track = New("Frame", {
                BackgroundColor3 = state and T.AccentHi or T.SurfaceAct,
                BorderSizePixel  = 0,
                Size             = UDim2.new(0, 36, 0, 20),
                Position         = UDim2.new(1, -44, 0.5, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                Parent           = row,
            })
            Corner(10, track)
            local thumb = New("Frame", {
                BackgroundColor3 = T.White,
                BorderSizePixel  = 0,
                Size             = UDim2.new(0, 14, 0, 14),
                Position         = state and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                Parent           = track,
            })
            Corner(7, thumb)

            local function apply(v)
                state = v
                Tw(track, { BackgroundColor3 = v and T.AccentHi or T.SurfaceAct }, 0.14)
                -- [NEW] Spring easing na kciuku
                Tw(thumb,
                    { Position = v and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0) },
                    0.2, Enum.EasingStyle.Spring, Enum.EasingDirection.Out)
                if callback then callback(v) end
            end

            New("TextButton", {
                BackgroundTransparency = 1,
                Size   = UDim2.new(1, 0, 1, 0),
                Text   = "",
                Parent = row,
            }).MouseButton1Click:Connect(function() apply(not state) end)

            local el = {}
            function el:SetValue(v) apply(v) end
            function el:GetValue()  return state end
            regEl(id, function() return state end, function(v) apply(v) end)
            return el
        end

