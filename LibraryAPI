            local selLbl = New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0.45, 0, 0, 0), Size = UDim2.new(0.4, 0, 1, 0), Text = selected, TextColor3 = T.TextSec, TextSize = 10, Font = Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Right, Parent = row })
            local chev = New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(1, -22, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Size = UDim2.new(0, 14, 0, 14), Text = "▾", TextColor3 = T.Accent, TextSize = 12, Font = Enum.Font.GothamBold, Parent = row })

            local drop = New("Frame", { BackgroundColor3 = T.SurfaceHov, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 1, 3), ClipsDescendants = true, ZIndex = 10, Parent = wrapper })
            Corner(9, drop); Stroke(T.Border, 1, drop)
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Parent = drop })
            Pad(4, 4, 0, 0, drop)

            local function buildItems(list)
                for _, c in ipairs(drop:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                for _, item in ipairs(list) do
                    local ob = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 28), Text = item, TextColor3 = (selected == item) and T.TextPri or T.TextSec, TextSize = 10, Font = Enum.Font.Gotham, ZIndex = 11, Parent = drop })
                    ob.MouseEnter:Connect(function() ob.BackgroundColor3 = T.SurfaceAct; Tw(ob, { BackgroundTransparency = 0 }, 0.07); ob.TextColor3 = T.TextPri end)
                    ob.MouseLeave:Connect(function() Tw(ob, { BackgroundTransparency = 1 }, 0.07); ob.TextColor3 = (selected == item) and T.TextPri or T.TextSec end)
                    ob.MouseButton1Click:Connect(function()
                        selected = item; selLbl.Text = item
                        closeDropdown()
                        if callback then callback(item) end
                    end)
                end
                return #list * 28 + 8
            end

            local dropH = buildItems(items)

            local function closeDropdown()
                if not open then return end
                open = false
                Tw(drop, { Size = UDim2.new(1,0,0,0) }, 0.14)
                Tw(wrapper, { Size = UDim2.new(1,0,0,36) }, 0.14)
                Tw(chev, { Rotation = 0 }, 0.14)
                if outsideConn then outsideConn:Disconnect() outsideConn = nil end
            end

            New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "", Parent = row }).MouseButton1Click:Connect(function()
                open = not open
                if open then
                    Tw(drop, { Size = UDim2.new(1,0,0,dropH) }, 0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    Tw(wrapper, { Size = UDim2.new(1,0,0,36+dropH+3) }, 0.18)
                    Tw(chev, { Rotation = 180 }, 0.16)

                    outsideConn = UserInputService.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then
                            local mouse = UserInputService:GetMouseLocation()
                            local absPos = drop.AbsolutePosition
                            local absSize = drop.AbsoluteSize
                            if not (mouse.X >= absPos.X and mouse.X <= absPos.X + absSize.X and
                                    mouse.Y >= absPos.Y and mouse.Y <= absPos.Y + absSize.Y) then
                                closeDropdown()
                            end
                        end
                    end)
                else
                    closeDropdown()
                end
            end)

            local el = {}
            function el:SetItems(list) items = list; dropH = buildItems(list) end
            function el:SetValue(v) selected = v; selLbl.Text = v end
            function el:GetValue()  return selected end
            regEl(id, function() return selected end, function(v) selected = v; selLbl.Text = v end)
            return el
        end

