        -- ── BUTTON ───────────────────────────────────────────────────────
        --[[
            tab:AddButton(label, desc, callback)
            Zwykły przycisk.
            Metody:
                :SetLabel(t)   - zmień tekst
                :SetEnabled(b) - włącz/wyłącz
        ]]
        function tab:AddButton(label, desc, callback)
            local h = desc and 44 or 34
            local row=New("TextButton",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,h),Text="",Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            local lblObj=New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,desc and 6 or 0),
                Size=UDim2.new(1,-40,0,desc and 18 or h),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            if desc then
                New("TextLabel",{BackgroundTransparency=1,
                    Position=UDim2.new(0,12,0,24),Size=UDim2.new(1,-40,0,14),
                    Text=desc,TextColor3=T.TextMut,TextSize=9,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            end
            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(1,-24,0.5,0),AnchorPoint=Vector2.new(0,0.5),
                Size=UDim2.new(0,16,0,16),Text="›",TextColor3=T.Accent,
                TextSize=18,Font=Enum.Font.GothamBold,Parent=row})

            local enabled=true
            row.MouseEnter:Connect(function() if enabled then Tw(row,{BackgroundColor3=T.SurfaceHov},0.1) end end)
            row.MouseLeave:Connect(function() if enabled then Tw(row,{BackgroundColor3=T.Surface},0.1) end end)
            row.MouseButton1Click:Connect(function()
                if not enabled then return end
                Tw(row,{BackgroundColor3=T.SurfaceAct},0.06)
                task.wait(0.06); Tw(row,{BackgroundColor3=T.Surface},0.1)
                if callback then callback() end
            end)

            local el={}
            function el:SetLabel(t) lblObj.Text=t end
            function el:SetEnabled(b)
                enabled=b
                lblObj.TextColor3 = b and T.TextPri or T.TextMut
            end
            return el
        end

        -- ── TOGGLE ───────────────────────────────────────────────────────
        --[[
            tab:AddToggle(label, desc, default, callback, id)
            id [string] - opcjonalne ID do zapisu konfiguracji
            Metody:
                :SetValue(bool) - ustaw stan z kodu
                :GetValue()     -> bool
        ]]
        function tab:AddToggle(label, desc, default, callback, id)
            local state = default or false
            local h     = desc and 44 or 34
            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,h),Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,desc and 6 or 0),
                Size=UDim2.new(1,-58,0,desc and 18 or h),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            if desc then
                New("TextLabel",{BackgroundTransparency=1,
                    Position=UDim2.new(0,12,0,24),Size=UDim2.new(1,-58,0,14),
                    Text=desc,TextColor3=T.TextMut,TextSize=9,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            end

            local track=New("Frame",{
                BackgroundColor3=state and T.AccentHi or T.SurfaceAct,
                BorderSizePixel=0,Size=UDim2.new(0,36,0,20),
                Position=UDim2.new(1,-44,0.5,0),AnchorPoint=Vector2.new(0,0.5),Parent=row})
            Corner(10,track)
            local thumb=New("Frame",{BackgroundColor3=T.White,BorderSizePixel=0,
                Size=UDim2.new(0,14,0,14),
                Position=state and UDim2.new(1,-17,0.5,0) or UDim2.new(0,3,0.5,0),
                AnchorPoint=Vector2.new(0,0.5),Parent=track}); Corner(7,thumb)

            local function apply(v)
                state=v
                Tw(track,{BackgroundColor3=v and T.AccentHi or T.SurfaceAct},0.14)
                Tw(thumb,{Position=v and UDim2.new(1,-17,0.5,0) or UDim2.new(0,3,0.5,0)},0.14,Enum.EasingStyle.Back)
                if callback then callback(v) end
            end

            New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
                Text="",Parent=row}).MouseButton1Click:Connect(function() apply(not state) end)

            local el={}
            function el:SetValue(v) apply(v) end
            function el:GetValue() return state end
            regEl(id, function() return state end, function(v) apply(v) end)
            return el
        end

        -- ── SLIDER ───────────────────────────────────────────────────────
        --[[
            tab:AddSlider(label, desc, min, max, default, callback, id)
            Metody:
                :SetValue(n) - ustaw wartość z kodu
                :GetValue()  -> number
        ]]
        function tab:AddSlider(label, desc, min, max, default, callback, id)
            min=min or 0; max=max or 100
            default=math.clamp(default or min, min, max)
            local val=default

            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,desc and 56 or 48),Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,6),Size=UDim2.new(0.65,0,0,16),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            local valLbl=New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(1,-50,0,6),Size=UDim2.new(0,44,0,16),
                Text=tostring(val),TextColor3=T.Accent,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,Parent=row})
            if desc then
                New("TextLabel",{BackgroundTransparency=1,
                    Position=UDim2.new(0,12,0,22),Size=UDim2.new(1,-60,0,12),
                    Text=desc,TextColor3=T.TextMut,TextSize=9,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            end

            local trackBg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(1,-24,0,5),
                Position=UDim2.new(0,12,0,desc and 40 or 32),Parent=row}); Corner(3,trackBg)

            local pct=(val-min)/(max-min)
            local fill=New("Frame",{BackgroundColor3=T.Accent,BorderSizePixel=0,
                Size=UDim2.new(pct,0,1,0),Parent=trackBg}); Corner(3,fill)
            local knob=New("Frame",{BackgroundColor3=T.White,BorderSizePixel=0,
                Size=UDim2.new(0,13,0,13),
                Position=UDim2.new(pct,-6,0.5,0),AnchorPoint=Vector2.new(0,0.5),
                Parent=trackBg}); Corner(7,knob)

            local function applyVal(v)
                v=math.clamp(math.floor(v+0.5),min,max)
                val=v; valLbl.Text=tostring(v)
                local p=(v-min)/(max-min)
                fill.Size=UDim2.new(p,0,1,0)
                knob.Position=UDim2.new(p,-6,0.5,0)
                if callback then callback(v) end
            end

            local sliding=false
            knob.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then
                    local rel=math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
                    applyVal(min+rel*(max-min))
                end
            end)

            local el={}
            function el:SetValue(v) applyVal(v) end
            function el:GetValue() return val end
            regEl(id, function() return val end, function(v) applyVal(v) end)
            return el
        end

        -- ── DROPDOWN ─────────────────────────────────────────────────────
        --[[
            tab:AddDropdown(label, items, default, callback, id)
            items   [table<string>]
            default [string] - domyślnie zaznaczona opcja
            Metody:
                :SetItems(t)    - odśwież listę opcji
                :SetValue(s)    - ustaw wybraną opcję
                :GetValue()     -> string
        ]]
        function tab:AddDropdown(label, items, default, callback, id)
            local selected = default or (items[1] or "Select...")
            local open     = false

            local wrapper=New("Frame",{BackgroundTransparency=1,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,34),ClipsDescendants=false,Parent=scroll})

            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,34),Parent=wrapper})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,0),Size=UDim2.new(0.45,0,1,0),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            local selLbl=New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0.45,0,0,0),Size=UDim2.new(0.42,0,1,0),
                Text=selected,TextColor3=T.TextSec,TextSize=10,
                Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Right,Parent=row})
            local chev=New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(1,-22,0.5,0),AnchorPoint=Vector2.new(0,0.5),
                Size=UDim2.new(0,14,0,14),Text="▾",TextColor3=T.Accent,
                TextSize=12,Font=Enum.Font.GothamBold,Parent=row})

            local drop=New("Frame",{BackgroundColor3=T.SurfaceHov,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,3),
                ClipsDescendants=true,ZIndex=10,Parent=wrapper})
            Corner(8,drop); Stroke(T.Border,1,drop)
            local dropLayout=New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Parent=drop})

            local function buildItems(list)
                for _,c in ipairs(drop:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for _,item in ipairs(list) do
                    local ob=New("TextButton",{BackgroundTransparency=1,
                        Size=UDim2.new(1,0,0,28),Text=item,
                        TextColor3=selected==item and T.TextPri or T.TextSec,
                        TextSize=10,Font=Enum.Font.Gotham,ZIndex=11,Parent=drop})
                    ob.MouseEnter:Connect(function()
                        ob.BackgroundColor3=T.SurfaceAct
                        Tw(ob,{BackgroundTransparency=0},0.07)
                        ob.TextColor3=T.TextPri
                    end)
                    ob.MouseLeave:Connect(function()
                        Tw(ob,{BackgroundTransparency=1},0.07)
                        ob.TextColor3=selected==item and T.TextPri or T.TextSec
                    end)
                    ob.MouseButton1Click:Connect(function()
                        selected=item; selLbl.Text=item
                        open=false
                        Tw(drop,{Size=UDim2.new(1,0,0,0)},0.16)
                        Tw(wrapper,{Size=UDim2.new(1,0,0,34)},0.16)
                        if callback then callback(item) end
                    end)
                end
                return #list*28
            end

            local dropH = buildItems(items)

            local toggleBtn=New("TextButton",{BackgroundTransparency=1,
                Size=UDim2.new(1,0,1,0),Text="",Parent=row})
            toggleBtn.MouseButton1Click:Connect(function()
                open=not open
                if open then
                    Tw(drop,{Size=UDim2.new(1,0,0,dropH)},0.16)
                    Tw(wrapper,{Size=UDim2.new(1,0,0,34+dropH+3)},0.16)
                else
                    Tw(drop,{Size=UDim2.new(1,0,0,0)},0.16)
                    Tw(wrapper,{Size=UDim2.new(1,0,0,34)},0.16)
                end
            end)

            local el={}
            function el:SetItems(list) items=list; dropH=buildItems(list) end
            function el:SetValue(v) selected=v; selLbl.Text=v end
            function el:GetValue() return selected end
            regEl(id,function() return selected end,function(v) selected=v; selLbl.Text=v end)
            return el
        end

        -- ── INPUT ────────────────────────────────────────────────────────
        --[[
            tab:AddInput(label, placeholder, callback, id)
            Jednolinijkowe pole tekstowe.
            Metody:
                :SetValue(s)  - ustaw tekst
                :GetValue()   -> string
        ]]
        function tab:AddInput(label, placeholder, callback, id)
            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,56),Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,5),Size=UDim2.new(1,-24,0,15),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            local ibg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(1,-24,0,26),Position=UDim2.new(0,12,0,24),Parent=row})
            Corner(6,ibg); Stroke(T.Border,1,ibg)
            local ibox=New("TextBox",{BackgroundTransparency=1,
                Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-16,1,0),
                PlaceholderText=placeholder or "...",PlaceholderColor3=T.TextMut,
                TextColor3=T.TextPri,TextSize=10,Font=Enum.Font.Gotham,
                TextXAlignment=Enum.TextXAlignment.Left,ClearTextOnFocus=false,Parent=ibg})
            ibox.Focused:Connect(function() Tw(ibg:FindFirstChildOfClass("UIStroke"),{Color=T.Accent},0.1) end)
            ibox.FocusLost:Connect(function(enter)
                Tw(ibg:FindFirstChildOfClass("UIStroke"),{Color=T.Border},0.1)
                if enter and callback then callback(ibox.Text) end
            end)

            local el={}
            function el:SetValue(v) ibox.Text=v end
            function el:GetValue() return ibox.Text end
            regEl(id,function() return ibox.Text end,function(v) ibox.Text=v end)
            return el
        end

        -- ── TEXTAREA ─────────────────────────────────────────────────────
        --[[
            tab:AddTextarea(label, placeholder, callback, id)
            Wieloliniowe pole tekstowe.
            Metody:
                :SetValue(s)
                :GetValue() -> string
        ]]
        function tab:AddTextarea(label, placeholder, callback, id)
            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,96),Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,5),Size=UDim2.new(1,-24,0,15),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

            local ibg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(1,-24,0,66),Position=UDim2.new(0,12,0,24),Parent=row})
            Corner(6,ibg); Stroke(T.Border,1,ibg)
            local ibox=New("TextBox",{BackgroundTransparency=1,
                Position=UDim2.new(0,8,0,4),Size=UDim2.new(1,-16,1,-8),
                PlaceholderText=placeholder or "...",PlaceholderColor3=T.TextMut,
                TextColor3=T.TextPri,TextSize=10,Font=Enum.Font.Gotham,
                TextXAlignment=Enum.TextXAlignment.Left,
                TextYAlignment=Enum.TextYAlignment.Top,
                MultiLine=true,ClearTextOnFocus=false,Parent=ibg})
            ibox.Focused:Connect(function() Tw(ibg:FindFirstChildOfClass("UIStroke"),{Color=T.Accent},0.1) end)
            ibox.FocusLost:Connect(function(enter)
                Tw(ibg:FindFirstChildOfClass("UIStroke"),{Color=T.Border},0.1)
                if enter and callback then callback(ibox.Text) end
            end)

            local el={}
            function el:SetValue(v) ibox.Text=v end
            function el:GetValue() return ibox.Text end
            regEl(id,function() return ibox.Text end,function(v) ibox.Text=v end)
            return el
        end

        -- ── KEYBIND ──────────────────────────────────────────────────────
        --[[
            tab:AddKeybind(label, desc, default, callback, id)
            default [Enum.KeyCode] - domyślny klawisz
            callback(key)          - wywoływana przy naciśnięciu klawisza
            Metody:
                :SetKey(Enum.KeyCode)
                :GetKey() -> Enum.KeyCode
        ]]
        function tab:AddKeybind(label, desc, default, callback, id)
            local currentKey = default or Enum.KeyCode.Unknown
            local listening  = false
            local h          = desc and 44 or 34

            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,h),Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,desc and 6 or 0),
                Size=UDim2.new(1,-90,0,desc and 18 or h),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            if desc then
                New("TextLabel",{BackgroundTransparency=1,
                    Position=UDim2.new(0,12,0,24),Size=UDim2.new(1,-90,0,14),
                    Text=desc,TextColor3=T.TextMut,TextSize=9,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            end

            local keyBg=New("TextButton",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(0,74,0,h-10),Position=UDim2.new(1,-82,0.5,0),
                AnchorPoint=Vector2.new(0,0.5),
                Text=currentKey==Enum.KeyCode.Unknown and "None" or currentKey.Name,
                TextColor3=T.Accent,TextSize=10,Font=Enum.Font.GothamBold,Parent=row})
            Corner(6,keyBg); Stroke(T.Border,1,keyBg)

            keyBg.MouseButton1Click:Connect(function()
                if listening then return end
                listening=true
                keyBg.Text="..."
                keyBg.TextColor3=T.Warning
                local conn; conn=UserInputService.InputBegan:Connect(function(i,gpe)
                    if gpe then return end
                    if i.UserInputType==Enum.UserInputType.Keyboard then
                        currentKey=i.KeyCode
                        keyBg.Text=i.KeyCode.Name
                        keyBg.TextColor3=T.Accent
                        listening=false; conn:Disconnect()
                    end
                end)
            end)

            UserInputService.InputBegan:Connect(function(i,gpe)
                if gpe or listening then return end
                if i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==currentKey then
                    if callback then callback(currentKey) end
                end
            end)

            local el={}
            function el:SetKey(k)
                currentKey=k
                keyBg.Text=k==Enum.KeyCode.Unknown and "None" or k.Name
            end
            function el:GetKey() return currentKey end
            regEl(id,function() return currentKey.Name end,
                function(v)
                    local ok,kc=pcall(function() return Enum.KeyCode[v] end)
                    if ok and kc then el:SetKey(kc) end
                end)
            return el
        end

        -- ── COLOR PICKER ─────────────────────────────────────────────────
        --[[
            tab:AddColorPicker(label, default, callback, id)
            default  [Color3]      - domyślny kolor
            callback(Color3)       - wywoływana przy zmianie koloru
            Metody:
                :SetColor(Color3)
                :GetColor() -> Color3
        ]]
        function tab:AddColorPicker(label, default, callback, id)
            local color = default or Color3.fromRGB(200,200,200)
            local h,s,v = RGB2HSV(color)
            local open   = false

            local wrapper=New("Frame",{BackgroundTransparency=1,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,34),ClipsDescendants=false,Parent=scroll})

            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,34),Parent=wrapper})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-60,1,0),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})

            local preview=New("Frame",{BackgroundColor3=color,BorderSizePixel=0,
                Size=UDim2.new(0,22,0,22),Position=UDim2.new(1,-34,0.5,0),
                AnchorPoint=Vector2.new(0,0.5),Parent=row}); Corner(5,preview)
            Stroke(T.Border,1,preview)

            -- picker panel
            local panel=New("Frame",{BackgroundColor3=T.SurfaceHov,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,3),
                ClipsDescendants=true,ZIndex=12,Parent=wrapper})
            Corner(8,panel); Stroke(T.Border,1,panel)
            Pad(10,10,10,10,panel)

            local panelLayout=New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,
                Padding=UDim.new(0,8),Parent=panel})

            -- SV square
            local svSize = 180
            local svFrame=New("Frame",{BackgroundColor3=HSV2RGB(h,1,1),BorderSizePixel=0,
                Size=UDim2.new(0,svSize,0,svSize),ZIndex=13,Parent=panel})
            Corner(6,svFrame)

            -- white gradient (S axis)
            local wGrad=New("Frame",{BackgroundColor3=T.White,BorderSizePixel=0,
                Size=UDim2.new(1,0,1,0),ZIndex=14,Parent=svFrame})
            Corner(6,wGrad)
            New("UIGradient",{Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,255)),
                ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))},
                Transparency=NumberSequence.new{
                    NumberSequenceKeypoint.new(0,0),
                    NumberSequenceKeypoint.new(1,1)},Parent=wGrad})

            -- black gradient (V axis)
            local bGrad=New("Frame",{BackgroundColor3=T.Black,BorderSizePixel=0,
                Size=UDim2.new(1,0,1,0),ZIndex=15,Parent=svFrame})
            Corner(6,bGrad)
            New("UIGradient",{Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,Color3.fromRGB(0,0,0)),
                ColorSequenceKeypoint.new(1,Color3.fromRGB(0,0,0))},
                Transparency=NumberSequence.new{
                    NumberSequenceKeypoint.new(0,1),
                    NumberSequenceKeypoint.new(1,0)},
                Rotation=90,Parent=bGrad})

            -- SV knob
            local svKnob=New("Frame",{BackgroundColor3=T.White,BorderSizePixel=0,
                Size=UDim2.new(0,10,0,10),
                Position=UDim2.new(s,-5,1-v,-5),
                ZIndex=16,Parent=svFrame}); Corner(5,svKnob)
            Stroke(T.Black,1,svKnob)

            -- H slider
            local hBar=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(0,svSize,0,14),ZIndex=13,Parent=panel})
            Corner(7,hBar)
            New("UIGradient",{Color=ColorSequence.new{
                ColorSequenceKeypoint.new(0,   Color3.fromRGB(255,0,0)),
                ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
                ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
                ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0,255,255)),
                ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
                ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
                ColorSequenceKeypoint.new(1,   Color3.fromRGB(255,0,0))},Parent=hBar})

            local hKnob=New("Frame",{BackgroundColor3=T.White,BorderSizePixel=0,
                Size=UDim2.new(0,10,1,0),Position=UDim2.new(h,-5,0,0),
                ZIndex=14,Parent=hBar}); Corner(5,hKnob); Stroke(T.Black,1,hKnob)

            -- hex input row
            local hexRow=New("Frame",{BackgroundTransparency=1,BorderSizePixel=0,
                Size=UDim2.new(0,svSize,0,24),ZIndex=13,Parent=panel})

            local hexBg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(1,-30,1,0),Parent=hexRow}); Corner(5,hexBg); Stroke(T.Border,1,hexBg)
            local hexBox=New("TextBox",{BackgroundTransparency=1,
                Size=UDim2.new(1,-8,1,0),Position=UDim2.new(0,4,0,0),
                Text=string.format("#%02X%02X%02X",math.floor(color.R*255),math.floor(color.G*255),math.floor(color.B*255)),
                TextColor3=T.TextPri,TextSize=10,Font=Enum.Font.GothamMono,
                TextXAlignment=Enum.TextXAlignment.Left,Parent=hexBg})

            local prevBox=New("Frame",{BackgroundColor3=color,BorderSizePixel=0,
                Size=UDim2.new(0,22,1,0),Position=UDim2.new(1,-22,0,0),Parent=hexRow})
            Corner(5,prevBox); Stroke(T.Border,1,prevBox)

            -- update function
            local function updateColor()
                color=HSV2RGB(h,s,v)
                preview.BackgroundColor3=color
                prevBox.BackgroundColor3=color
                svFrame.BackgroundColor3=HSV2RGB(h,1,1)
                svKnob.Position=UDim2.new(s,-5,1-v,-5)
                hKnob.Position=UDim2.new(h,-5,0,0)
                hexBox.Text=string.format("#%02X%02X%02X",
                    math.floor(color.R*255),math.floor(color.G*255),math.floor(color.B*255))
                if callback then callback(color) end
            end

            -- SV drag
            local svDrag=false
            svFrame.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if svDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
                    local ap=svFrame.AbsolutePosition; local as=svFrame.AbsoluteSize
                    s=math.clamp((i.Position.X-ap.X)/as.X,0,1)
                    v=1-math.clamp((i.Position.Y-ap.Y)/as.Y,0,1)
                    updateColor()
                end
            end)

            -- H drag
            local hDrag=false
            hBar.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then hDrag=true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then hDrag=false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if hDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
                    h=math.clamp((i.Position.X-hBar.AbsolutePosition.X)/hBar.AbsoluteSize.X,0,1)
                    updateColor()
                end
            end)

            -- hex input
            hexBox.FocusLost:Connect(function()
                local hex=hexBox.Text:gsub("#","")
                if #hex==6 then
                    local r=tonumber(hex:sub(1,2),16)
                    local g=tonumber(hex:sub(3,4),16)
                    local b=tonumber(hex:sub(5,6),16)
                    if r and g and b then
                        color=Color3.fromRGB(r,g,b)
                        h,s,v=RGB2HSV(color)
                        updateColor()
                    end
                end
            end)

            -- toggle open
            local panelH = svSize + 14 + 24 + 10*3 + 8*2  -- content + paddings
            New("TextButton",{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),
                Text="",Parent=row}).MouseButton1Click:Connect(function()
                open=not open
                if open then
                    Tw(panel,{Size=UDim2.new(1,0,0,panelH)},0.18)
                    Tw(wrapper,{Size=UDim2.new(1,0,0,34+panelH+3)},0.18)
                else
                    Tw(panel,{Size=UDim2.new(1,0,0,0)},0.18)
                    Tw(wrapper,{Size=UDim2.new(1,0,0,34)},0.18)
                end
            end)

            local el={}
            function el:SetColor(c)
                color=c; h,s,v=RGB2HSV(c); updateColor()
            end
            function el:GetColor() return color end
            regEl(id,
                function() return {R=color.R,G=color.G,B=color.B} end,
                function(d) if type(d)=="table" then el:SetColor(Color3.new(d.R,d.G,d.B)) end end)
            return el
        end

        -- ── PROGRESS BAR ─────────────────────────────────────────────────
        --[[
            tab:AddProgressBar(label, default)
            default [number 0-100]
            Metody:
                :SetValue(n)  - ustaw % (0-100)
                :GetValue()   -> number
        ]]
        function tab:AddProgressBar(label, default)
            local val = math.clamp(default or 0, 0, 100)
            local row=New("Frame",{BackgroundColor3=T.Surface,BorderSizePixel=0,
                Size=UDim2.new(1,0,0,48),Parent=scroll})
            Corner(8,row); Stroke(T.Border,1,row)

            New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(0,12,0,6),Size=UDim2.new(0.7,0,0,15),
                Text=label,TextColor3=T.TextPri,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,Parent=row})
            local pctLbl=New("TextLabel",{BackgroundTransparency=1,
                Position=UDim2.new(1,-46,0,6),Size=UDim2.new(0,40,0,15),
                Text=val.."%",TextColor3=T.Accent,TextSize=11,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,Parent=row})

            local trackBg=New("Frame",{BackgroundColor3=T.SurfaceAct,BorderSizePixel=0,
                Size=UDim2.new(1,-24,0,8),Position=UDim2.new(0,12,0,30),Parent=row})
            Corner(4,trackBg)
            local fill=New("Frame",{BackgroundColor3=T.Accent,BorderSizePixel=0,
                Size=UDim2.new(val/100,0,1,0),Parent=trackBg}); Corner(4,fill)

            local el={}
            function el:SetValue(n)
                n=math.clamp(n,0,100); val=n
                pctLbl.Text=n.."%"
                Tw(fill,{Size=UDim2.new(n/100,0,1,0)},0.2)
            end
            function el:GetValue() return val end
            return el
        end

        return tab
    end -- AddTab

    return Win
end -- CreateWindow

return xev0r

